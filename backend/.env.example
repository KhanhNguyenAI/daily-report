# Copy file này thành .env rồi điền giá trị thật (KHÔNG commit .env)

# Đường dẫn tới service account key JSON tải từ Firebase console
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Gemini API key — lấy tại https://aistudio.google.com/apikey
GEMINI_API_KEY=

# CORS: các origin frontend được phép gọi (phẩy ngăn cách). Khi deploy thêm URL Vercel.
CORS_ORIGINS=http://localhost:5173

# Auth: production để true (bắt đăng nhập Google). Local dev đặt false để khỏi đăng nhập.
AUTH_ENABLED=false
