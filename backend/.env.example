# Copy file này thành .env rồi điền giá trị thật (KHÔNG commit .env)

# Đường dẫn tới service account key JSON tải từ Firebase console
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Gemini API key — lấy tại https://aistudio.google.com/apikey (bắt đầu bằng AIzaSy...)
GEMINI_API_KEY=

# Giai đoạn 3 — auth
JWT_SECRET=
