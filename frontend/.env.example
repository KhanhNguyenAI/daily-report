# Copy thành .env.local để chạy local. Khi deploy Vercel thì điền các biến này ở dashboard.

# URL backend. Local: http://localhost:8000. Production: URL Render (vd https://takenote-api.onrender.com)
VITE_API_URL=http://localhost:8000

# Firebase Web config — lấy ở Firebase console → Project settings → General → Your apps → Web app.
# ĐỂ TRỐNG khi chạy local (backend AUTH_ENABLED=false) thì app bỏ qua đăng nhập.
# Điền đủ khi deploy để bật đăng nhập Google.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
